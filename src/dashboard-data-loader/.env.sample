# Postgres connection
PGHOST=localhost
PGPORT=5432
PGDATABASE=dev_db
PGUSER=dev_user
PGPASSWORD=dev_password

# GitHub API (for API loaders)
GITHUB_ORGANIZATION=
GITHUB_ENTERPRISE=
GITHUB_TOKEN=
GITHUB_API_VERSION=2022-11-28
# Scope: 'enterprise' or 'organization'
GITHUB_API_SCOPE=organization

# Teams (comma-separated slugs) when loading team metrics via API
# Example: TEAMS=team-a,team-b,team-c
TEAMS=

# Optional date range (YYYY-MM-DD)
SINCE=
UNTIL=

# Seats API loader options
# Snapshot date (defaults to today if empty)
DATE=
# Page size for seats API (default 100)
PER_PAGE=100

# Scope metadata (optional)
SCOPE_ENTERPRISE=
SCOPE_ORG=
SCOPE_TEAM=

# File paths (you can override per-run via env or CLI)
METRICS_JSON=./samples/metrics.json
SEATS_JSON=./samples/seats.json
# Seats paging (optional)
SEATS_PAGE=1
# If your seats JSON contains a top-level flag indicating more pages
SEATS_HAS_NEXT_PAGE=false
