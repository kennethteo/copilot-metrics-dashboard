GITHUB_ENTERPRISE=your-github-enterprise-name
GITHUB_ORGANIZATION=your-github-organization-name
GITHUB_TOKEN=your-github-token
GITHUB_API_VERSION=2022-11-28
GITHUB_API_SCOPE=organization

# PostgreSQL connection string
# Example for local docker compose: postgresql://dev_user:dev_password@localhost:5432/dev_db
DATABASE_URL=postgresql://dev_user:dev_password@localhost:5432/dev_db